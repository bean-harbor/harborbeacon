IM_AGENT_CONTRACT_VERSION=2.0
IM_AGENT_HOST=127.0.0.1
IM_AGENT_PORT=8787
IM_AGENT_DATA_DIR=__INSTALL_ROOT__/runtime/harborgate/sessions
IM_AGENT_STATE_DIR=__INSTALL_ROOT__/runtime/harborgate
IM_AGENT_PUBLIC_ORIGIN=http://harborbeacon.local:8787
WEIXIN_STATE_DIR=__INSTALL_ROOT__/runtime/harborgate/weixin

HARBORBEACON_WEB_API_URL=http://127.0.0.1:4174
HARBORBEACON_WEB_API_TOKEN=replace-me
HARBORBEACON_TASK_API_URL=http://127.0.0.1:4174
HARBORBEACON_TASK_API_TOKEN=replace-me
HARBORBEACON_ADMIN_API_URL=http://127.0.0.1:4174
