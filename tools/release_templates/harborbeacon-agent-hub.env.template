# HarborBeacon / HarborDesk / HarborGate release runtime
WORKSPACE_ROOT=__INSTALL_ROOT__/current
HARBOR_HTTP_BIND=0.0.0.0:4174
HARBOR_PUBLIC_ORIGIN=http://harborbeacon.local:4174
HARBORDESK_DIST=__INSTALL_ROOT__/current/harbordesk/dist/harbordesk
HARBOR_HARBOROS_USER=__SERVICE_USER__
HARBOR_HARBOROS_WRITABLE_ROOT=__WRITABLE_ROOT__
HARBOR_KNOWLEDGE_INDEX_ROOT=__WRITABLE_ROOT__/knowledge-index

HARBOR_MODEL_API_BASE_URL=http://127.0.0.1:4174/api/inference/v1
HARBOR_MODEL_API_TOKEN=replace-me
# Keep openai_proxy as the default backend until the spawned benchmark gate
# explicitly clears candle for promotion.
HARBOR_MODEL_API_BACKEND=openai_proxy
HARBOR_MODEL_API_UPSTREAM_BASE_URL=http://127.0.0.1:11434/v1
HARBOR_MODEL_API_CHAT_MODEL=harbor-local-chat
HARBOR_MODEL_API_EMBEDDING_MODEL=harbor-local-embed
HARBOR_MODEL_API_REQUEST_TIMEOUT_MS=30000

HARBOR_VLM_SIDECAR_ENABLE=0
# Transitional fallback only; production inference is exposed through
# /api/inference/* on the HarborBeacon port.
HARBOR_VLM_BIND=127.0.0.1:4196
HARBOR_VLM_MODEL_ID=HuggingFaceTB/SmolVLM-256M-Instruct
HARBOR_VLM_MODEL_PATH=__WRITABLE_ROOT__/models/huggingfacetb-smolvlm-256m-instruct
HARBOR_VLM_DEVICE=cpu
HARBOR_VLM_MAX_NEW_TOKENS=96
HARBOR_VLM_LOCAL_FILES_ONLY=1
HARBOR_VLM_PRELOAD=1
# HARBOR_VLM_PYTHON=__WRITABLE_ROOT__/vlm-sidecar-venv/bin/python

# Optional Candle candidate overrides for the 4186 side lane.
# Keep 4176 on openai_proxy until the spawned benchmark gate clears promotion.
# HARBOR_MODEL_API_CANDLE_CHAT_MODEL_ID=Qwen/Qwen3-1.7B
# HARBOR_MODEL_API_CANDLE_EMBEDDING_MODEL_ID=jinaai/jina-embeddings-v2-base-zh
# HARBOR_MODEL_API_CANDLE_CACHE_DIR=__WRITABLE_ROOT__/candle-cache

HARBOR_TASK_API_URL=http://127.0.0.1:4174
HARBOR_TASK_API_ADMIN_STATE=__INSTALL_ROOT__/runtime/admin-console.json
HARBOR_TASK_API_DEVICE_REGISTRY=__INSTALL_ROOT__/runtime/device-registry.json
HARBOR_TASK_API_CONVERSATIONS=__INSTALL_ROOT__/runtime/task-api-conversations.json
HARBOR_TASK_API_BEARER_TOKEN=replace-me

HARBORGATE_BASE_URL=http://127.0.0.1:8787
